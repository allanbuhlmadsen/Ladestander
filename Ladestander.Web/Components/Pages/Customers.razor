@page "/customers"

@using System.Net.Http.Json
@using Ladestander.Web.DTOs
@using System.Net.Http.Headers
@using Ladestander.Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Kunder</h3>

<hr />

<h4>Opret kunde</h4>

<div class="mb-3">
    <label>RFID-nummer</label>
    <input class="form-control" @bind="_createRfidNumber" />
</div>

<div class="mb-3">
    <label>Fornavn</label>
    <input class="form-control" @bind="_createFirstName" />
</div>

<div class="mb-3">
    <label>Mellemnavn</label>
    <input class="form-control" @bind="_createMiddleName" />
</div>

<div class="mb-3">
    <label>Efternavn</label>
    <input class="form-control" @bind="_createLastName" />
</div>

<div class="mb-3">
    <label>E-mail</label>
    <input class="form-control" @bind="_createEmail" />
</div>

<button class="btn btn-primary" @onclick="CreateCustomerAsync">
    Opret kunde
</button>

@if (!string.IsNullOrWhiteSpace(_createMessage))
{
    <p class="mt-2">@_createMessage</p>
}

@if (!string.IsNullOrWhiteSpace(_deleteMessage))
{
    <p class="mt-2">@_deleteMessage</p>
}

<hr />

@if (_editCustomerId is not null)
{
    <hr />

    <h4>Rediger kunde</h4>

    <div class="mb-3">
        <label>RFID-nummer</label>
        <input class="form-control" @bind="_editRfidNumber" />
    </div>

    <div class="mb-3">
        <label>Fornavn</label>
        <input class="form-control" @bind="_editFirstName" />
    </div>

    <div class="mb-3">
        <label>Mellemnavn</label>
        <input class="form-control" @bind="_editMiddleName" />
    </div>

    <div class="mb-3">
        <label>Efternavn</label>
        <input class="form-control" @bind="_editLastName" />
    </div>

    <div class="mb-3">
        <label>E-mail</label>
        <input class="form-control" @bind="_editEmail" />
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input"
               type="checkbox"
               @bind="_editIsActive" />

        <label class="form-check-label">
            Aktiv
        </label>
    </div>

    <button class="btn btn-primary" @onclick="UpdateCustomerAsync">
        Gem ændringer
    </button>

    @if (!string.IsNullOrWhiteSpace(_editMessage))
    {
        <p class="mt-2">@_editMessage</p>
    }
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p class="text-danger">@_errorMessage</p>
}
else if (_customers is null)
{
    <p>Indlæser...</p>
}
else if (!_customers.Any())
{
    <p>Ingen kunder fundet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Fulde navn</th>
                <th>E-mail</th>
                <th>Aktiv</th>
                <th>Handlinger</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var customer in _customers)
            {
                <tr>
                    <td>@customer.CustomerId</td>
                    <td>@customer.FullName</td>
                    <td>@customer.Email</td>
                    <td>@(customer.IsActive ? "Ja" : "Nej")</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick="() => StartEdit(customer)">
                            Rediger
                        </button>

                        @if (customer.IsActive)
                        {
                            <button class="btn btn-sm btn-warning ms-2" @onclick="() => SoftDeleteCustomerAsync(customer.CustomerId)">
                                Deaktiver
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {

    private string _createRfidNumber = "";
    private string _createFirstName = "";
    private string? _createMiddleName;
    private string _createLastName = "";
    private string? _createEmail;
    private string? _createMessage;

    private int? _editCustomerId;
    private string _editRfidNumber = "";
    private string _editFirstName = "";
    private string? _editMiddleName;
    private string _editLastName = "";
    private string? _editEmail;
    private bool _editIsActive;
    private string? _editMessage;
    private string? _deleteMessage;

    private List<CustomerResponseDto>? _customers;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            _errorMessage = "Du skal være logget ind for at se kunder.";
            _customers = new List<CustomerResponseDto>();
            return;
        }

        var token = user.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            _customers = new List<CustomerResponseDto>();
            return;
        }

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            return;
        }

        _customers = await client.GetFromJsonAsync<List<CustomerResponseDto>>(
            "api/customers");
    }

    private async Task CreateCustomerAsync()
    {
        _createMessage = null;

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _createMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var request = new CreateCustomerRequestDto(
            _createRfidNumber,
            _createFirstName,
            _createMiddleName,
            _createLastName,
            _createEmail,
            null,
            null,
            null,
            null
        );

        var response = await client.PostAsJsonAsync(
            "api/customers",
            request);

        if (!response.IsSuccessStatusCode)
        {
            _createMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Kunden kunne ikke oprettes.");

            return;
        }

        _createMessage = "Kunden blev oprettet.";

        _customers =
            await client.GetFromJsonAsync<List<CustomerResponseDto>>(
                "api/customers");
    }

    private void StartEdit(CustomerResponseDto customer)
    {
        _editCustomerId = customer.CustomerId;

        _editRfidNumber = customer.RfidNumber;
        _editFirstName = customer.FirstName;
        _editMiddleName = customer.MiddleName;
        _editLastName = customer.LastName;
        _editEmail = customer.Email;
        _editIsActive = customer.IsActive;

        _editMessage = null;
    }
    
    private async Task UpdateCustomerAsync()
    {
        if (_editCustomerId is null)
        {
            _editMessage = "Ingen kunde valgt.";
            return;
        }

        _editMessage = null;

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _editMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var request = new UpdateCustomerRequestDto(
            _editRfidNumber,
            _editFirstName,
            _editMiddleName,
            _editLastName,
            _editEmail,
            null,
            null,
            null,
            null,
            _editIsActive
        );

        var response = await client.PutAsJsonAsync(
            $"api/customers/{_editCustomerId}",
            request);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadFromJsonAsync<ErrorResponseDto>();

            _editMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Kunden kunne ikke opdateres.");

            return;
        }

        _editMessage = "Kunden blev opdateret.";

        _customers =
            await client.GetFromJsonAsync<List<CustomerResponseDto>>(
                "api/customers");

        _editCustomerId = null;
    }

    private async Task SoftDeleteCustomerAsync(int customerId)
    {
        _deleteMessage = null;

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _deleteMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var response =
            await client.DeleteAsync($"api/customers/{customerId}");

        if (!response.IsSuccessStatusCode)
        {
            _deleteMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Kunden kunne ikke deaktiveres.");

            return;
        }

        _deleteMessage = "Kunden blev deaktiveret.";

        _customers =
            await client.GetFromJsonAsync<List<CustomerResponseDto>>(
                "api/customers");
    }

    private async Task<HttpClient?> CreateAuthorizedClientAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var token = authState.User.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return null;
        }

        var client = HttpClientFactory.CreateClient("LadestanderApi");

        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        return client;
    }
}