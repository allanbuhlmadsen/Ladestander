@page "/charging-sessions"

@using System.Net.Http.Json
@using Ladestander.Web.DTOs
@using System.Net.Http.Headers
@using Ladestander.Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Ladeposter</h3>

<hr />

<h4>Opret test-ladepost</h4>

<div class="mb-3">
    <label>Kunde</label>

    <select class="form-select" @bind="_importCustomerId">
        <option value="0">Vælg kunde</option>

        @if (_customers is not null)
        {
            @foreach (var customer in _customers)
            {
                <option value="@customer.CustomerId">
                    @customer.CustomerId - @customer.FullName
                </option>
            }
        }
    </select>
</div>

<div class="mb-3">
    <label>Periode</label>

    <select class="form-select" @bind="_importBillingPeriodId">
        <option value="0">Vælg periode</option>

        @if (_billingPeriods is not null)
        {
            @foreach (var billingPeriod in _billingPeriods)
            {
                <option value="@billingPeriod.BillingPeriodId">
                    @billingPeriod.BillingPeriodId - @billingPeriod.Name
                </option>
            }
        }
    </select>
</div>

<div class="mb-3">
    <label>Energi kWh</label>
    <input class="form-control" type="number" step="0.001" @bind="_importEnergyKWh" />
</div>

<button class="btn btn-primary" @onclick="ImportChargingSessionAsync">
    Opret test-ladepost
</button>

@if (!string.IsNullOrWhiteSpace(_importMessage))
{
    <p class="mt-2">@_importMessage</p>
}

<hr />

<h4>Importér CSV</h4>

<div class="mb-3">
    <label>Periode</label>

    <select class="form-select" @bind="_csvBillingPeriodId">
        <option value="0">Vælg periode</option>

        @if (_billingPeriods is not null)
        {
            @foreach (var billingPeriod in _billingPeriods)
            {
                <option value="@billingPeriod.BillingPeriodId">
                    @billingPeriod.BillingPeriodId - @billingPeriod.Name
                </option>
            }
        }
    </select>
</div>

<div class="mb-3">
    <label>CSV-fil</label>
    <InputFile OnChange="OnCsvFileSelected" />
</div>

<button class="btn btn-primary" @onclick="ImportCsvAsync">
    Importér CSV
</button>

@if (!string.IsNullOrWhiteSpace(_csvImportMessage))
{
    <p class="mt-2">@_csvImportMessage</p>
}

<hr />

<h4>Filtrer ladeposter</h4>

<div class="mb-3">
    <label>Kunde</label>

    <select class="form-select" @bind="_filterCustomerId">
        <option value="0">Vælg kunde</option>

        @if (_customers is not null)
        {
            @foreach (var customer in _customers)
            {
                <option value="@customer.CustomerId">
                    @customer.CustomerId - @customer.FullName
                </option>
            }
        }
    </select>
</div>

<div class="mb-3">
    <label>Periode</label>

    <select class="form-select" @bind="_filterBillingPeriodId">
        <option value="0">Vælg periode</option>

        @if (_billingPeriods is not null)
        {
            @foreach (var billingPeriod in _billingPeriods)
            {
                <option value="@billingPeriod.BillingPeriodId">
                    @billingPeriod.BillingPeriodId - @billingPeriod.Name
                </option>
            }
        }
    </select>
</div>

<button class="btn btn-secondary" @onclick="FilterChargingSessionsAsync">
    Filtrer
</button>

<button class="btn btn-outline-secondary ms-2" @onclick="LoadAllChargingSessionsAsync">
    Vis alle
</button>

@if (!string.IsNullOrWhiteSpace(_filterMessage))
{
    <p class="mt-2">@_filterMessage</p>
}

<hr />

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p class="text-danger">@_errorMessage</p>
}
else if (_chargingSessions is null)
{
    <p>Indlæser...</p>
}
else if (!_chargingSessions.Any())
{
    <p>Ingen ladeposter fundet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Kunde</th>
                <th>Periode</th>
                <th>Faktura</th>
                <th>Lader</th>
                <th>Starttidspunkt</th>
                <th>Energi kWh</th>
                <th>Kildebruger</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var session in _chargingSessions)
            {
                <tr>
                    <td>@session.ChargingSessionId</td>
                    <td>@session.CustomerId</td>
                    <td>@session.BillingPeriodId</td>
                    <td>@session.InvoiceId</td>
                    <td>@session.ChargerAlias</td>
                    <td>@session.StartTime</td>
                    <td>@session.EnergyKWh</td>
                    <td>@session.SourceUserName</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int _importCustomerId;
    private int _importBillingPeriodId;
    private decimal _importEnergyKWh;
    private string? _importMessage;
    private int _csvBillingPeriodId;
    private IBrowserFile? _csvFile;
    private string? _csvImportMessage;

    private int _filterCustomerId;
    private int _filterBillingPeriodId;
    private string? _filterMessage;

    private List<ChargingSessionResponseDto>? _chargingSessions;
    private List<CustomerResponseDto>? _customers;
    private List<BillingPeriodResponseDto>? _billingPeriods;

    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            _errorMessage = "Du skal være logget ind for at se ladeposter.";
            _chargingSessions = new List<ChargingSessionResponseDto>();
            return;
        }

        var token = user.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            _chargingSessions = new List<ChargingSessionResponseDto>();
            return;
        }

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            return;
        }

        await LoadCustomersAsync();
        await LoadBillingPeriodsAsync();
        await LoadAllChargingSessionsAsync();
    }

    private async Task ImportChargingSessionAsync()
    {
        _importMessage = null;

        var request = new ChargingSessionImportRequestDto(
            _importCustomerId,
            _importBillingPeriodId,
            "Testlader",
            DateTime.UtcNow,
            _importEnergyKWh,
            "Frontend-test"
        );

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _importMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var response = await client.PostAsJsonAsync(
            "api/charging-sessions/import",
            request);

        if (!response.IsSuccessStatusCode)
        {
            _importMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Test-ladeposten kunne ikke oprettes.");

            return;
        }

        _importMessage = "Test-ladeposten blev oprettet.";

        _chargingSessions =
            await client.GetFromJsonAsync<List<ChargingSessionResponseDto>>(
                "api/charging-sessions");
    }

    private void OnCsvFileSelected(InputFileChangeEventArgs e)
    {
        _csvFile = e.File;
    }

    private async Task ImportCsvAsync()
    {
        _csvImportMessage = null;

        if (_csvFile is null)
        {
            _csvImportMessage = "Vælg en CSV-fil.";
            return;
        }

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _csvImportMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        using var content = new MultipartFormDataContent();

        using var stream = _csvFile.OpenReadStream(maxAllowedSize: 10_000_000);

        var fileContent = new StreamContent(stream);

        fileContent.Headers.ContentType =
            new System.Net.Http.Headers.MediaTypeHeaderValue("text/csv");

        content.Add(fileContent, "file", _csvFile.Name);

        content.Add(
            new StringContent(_csvBillingPeriodId.ToString()),
            "billingPeriodId");

        var response = await client.PostAsync(
            "api/charging-sessions/import-csv",
            content);

        if (!response.IsSuccessStatusCode)
        {
            _csvImportMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "CSV-importen fejlede.");

            return;
        }

        var importResult =
            await response.Content.ReadFromJsonAsync<ChargingSessionCsvImportResultDto>();

        if (importResult is null)
        {
            _csvImportMessage = "CSV-importen blev gennemført, men der blev ikke returneret et importresultat.";
        }
        else if (importResult.Errors.Any())
        {
            _csvImportMessage =
                $"Importeret: {importResult.ImportedCount}. " +
                $"Sprunget over: {importResult.SkippedCount}. " +
                string.Join(" ", importResult.Errors);
        }
        else
        {
            _csvImportMessage =
                $"CSV-importen blev gennemført. Importeret: {importResult.ImportedCount}. Sprunget over: {importResult.SkippedCount}.";
        }

        _chargingSessions =
            await client.GetFromJsonAsync<List<ChargingSessionResponseDto>>(
                "api/charging-sessions");
    }

    private async Task LoadAllChargingSessionsAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _filterMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _chargingSessions =
            await client.GetFromJsonAsync<List<ChargingSessionResponseDto>>(
                "api/charging-sessions");

        _filterMessage = null;
    }

    private async Task FilterChargingSessionsAsync()
    {
        _filterMessage = null;

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _filterMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var allChargingSessions =
            await client.GetFromJsonAsync<List<ChargingSessionResponseDto>>(
                "api/charging-sessions");

        if (allChargingSessions is null)
        {
            _chargingSessions = new List<ChargingSessionResponseDto>();
            _filterMessage = "Ingen ladeposter fundet.";
            return;
        }

        _chargingSessions = allChargingSessions
            .Where(session =>
                (_filterCustomerId == 0 || session.CustomerId == _filterCustomerId)
                &&
                (_filterBillingPeriodId == 0 || session.BillingPeriodId == _filterBillingPeriodId))
            .ToList();

        _filterMessage = "Filter anvendt.";
    }

    private async Task LoadCustomersAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _customers =
            await client.GetFromJsonAsync<List<CustomerResponseDto>>(
                "api/customers");
    }

    private async Task LoadBillingPeriodsAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _billingPeriods =
            await client.GetFromJsonAsync<List<BillingPeriodResponseDto>>(
                "api/billing-periods");
    }

    private async Task<HttpClient?> CreateAuthorizedClientAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var token = authState.User.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return null;
        }

        var client = HttpClientFactory.CreateClient("LadestanderApi");

        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        return client;
    }
}