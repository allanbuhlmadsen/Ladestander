@page "/invoices"

@using System.Net.Http.Json
@using Ladestander.Web.DTOs
@using System.Net.Http.Headers
@using Ladestander.Web.Helpers
@using Microsoft.AspNetCore.Components.Authorization

@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<h3>Fakturaer</h3>

<hr />

<h4>Generér faktura</h4>

<div class="mb-3">
    <label>Kunde</label>

    <select class="form-select" @bind="_generateCustomerId">

        <option value="0">Vælg kunde</option>

        @if (_customers is not null)
        {
            @foreach (var customer in _customers)
            {
                <option value="@customer.CustomerId">
                    @customer.CustomerId - @customer.FullName
                </option>
            }
        }

    </select>
</div>

<div class="mb-3">
    <label>Periode</label>

    <select class="form-select" @bind="_generateBillingPeriodId">

        <option value="0">Vælg periode</option>

        @if (_billingPeriods is not null)
        {
            @foreach (var billingPeriod in _billingPeriods)
            {
                <option value="@billingPeriod.BillingPeriodId">
                    @billingPeriod.BillingPeriodId - @billingPeriod.Name
                </option>
            }
        }

    </select>
</div>

<button class="btn btn-primary" @onclick="GenerateInvoiceAsync">
    Generér faktura
</button>

@if (!string.IsNullOrWhiteSpace(_generateMessage))
{
    <p class="mt-2">@_generateMessage</p>
}

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <p class="mt-2">@_statusMessage</p>
}

<hr />

<h4>Filtrer fakturaer</h4>

<div class="mb-3">
    <label>Kunde</label>

    <select class="form-select" @bind="_filterCustomerId">

        <option value="0">Vælg kunde</option>

        @if (_customers is not null)
        {
            @foreach (var customer in _customers)
            {
                <option value="@customer.CustomerId">
                    @customer.CustomerId - @customer.FullName
                </option>
            }
        }

    </select>
</div>

<div class="mb-3">
    <label>Periode</label>

    <select class="form-select" @bind="_filterBillingPeriodId">

        <option value="0">Vælg periode</option>

        @if (_billingPeriods is not null)
        {
            @foreach (var billingPeriod in _billingPeriods)
            {
                <option value="@billingPeriod.BillingPeriodId">
                    @billingPeriod.BillingPeriodId - @billingPeriod.Name
                </option>
            }
        }

    </select>
</div>

<button class="btn btn-secondary" @onclick="FilterInvoicesAsync">
    Filtrer
</button>

<button class="btn btn-outline-secondary ms-2" @onclick="LoadAllInvoicesAsync">
    Vis alle
</button>

@if (!string.IsNullOrWhiteSpace(_filterMessage))
{
    <p class="mt-2">@_filterMessage</p>
}

<hr />

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p class="text-danger">@_errorMessage</p>
}
else if (_invoices is null)
{
    <p>Indlæser...</p>
}
else if (!_invoices.Any())
{
    <p>Ingen fakturaer fundet.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Kunde</th>
                <th>Periode</th>
                <th>Status</th>
                <th>Sendt</th>
                <th>Betalt</th>
                <th>Samlet kWh</th>
                <th>Samlet beløb</th>
                <th>Oprettet</th>
                <th>Handlinger</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var invoice in _invoices)
            {
                <tr>
                    <td>@GetCustomerName(invoice.CustomerId)</td>
                    <td>@GetBillingPeriodName(invoice.BillingPeriodId)</td>
                    <td>@invoice.BillingPeriodId</td>
                    <td>
                        @(invoice.Status switch
                        {
                            "Draft" => "Kladde",
                            "Sent" => "Sendt",
                            "Paid" => "Betalt",
                            _ => invoice.Status
                        })
                    </td>
                    <td>@(invoice.IsSent ? "Ja" : "Nej")</td>
                    <td>@(invoice.IsPaid ? "Ja" : "Nej")</td>
                    <td>@invoice.TotalEnergyKWh.ToString("0.###")</td>
                    <td>@invoice.TotalAmount.ToString("0.00") kr.</td>
                    <td>@invoice.CreatedAt?.ToString("dd-MM-yyyy HH:mm")</td>
                    <td>
                        <button class="btn btn-sm btn-secondary" @onclick='() => UpdateInvoiceStatusAsync(invoice.InvoiceId, "Sent")'>
                            Markér som sendt
                        </button>

                        <button class="btn btn-sm btn-success ms-2" @onclick='() => UpdateInvoiceStatusAsync(invoice.InvoiceId, "Paid")'>
                            Markér som betalt
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int _generateCustomerId;
    private int _generateBillingPeriodId;
    private string? _generateMessage;
    private string? _statusMessage;

    private int _filterCustomerId;
    private int _filterBillingPeriodId;
    private string? _filterMessage;

    private List<InvoiceResponseDto>? _invoices;
    private List<CustomerResponseDto>? _customers;
    private List<BillingPeriodResponseDto>? _billingPeriods;

    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            _errorMessage = "Du skal være logget ind for at se fakturaer.";
            _invoices = new List<InvoiceResponseDto>();
            return;
        }

        var token = user.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            _invoices = new List<InvoiceResponseDto>();
            return;
        }

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            return;
        }

        await LoadCustomersAsync();
        await LoadBillingPeriodsAsync();
        await LoadAllInvoicesAsync();
    }

    private async Task GenerateInvoiceAsync()
    {
        _generateMessage = null;

        var request = new GenerateInvoiceRequestDto(
            _generateCustomerId,
            _generateBillingPeriodId
        );

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _generateMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var response = await client.PostAsJsonAsync(
            "api/invoices/generate",
            request);

        if (!response.IsSuccessStatusCode)
        {
            _generateMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Fakturaen kunne ikke genereres.");

            return;
        }

        _generateMessage = "Fakturaen blev genereret.";

        _invoices = await client.GetFromJsonAsync<List<InvoiceResponseDto>>(
            "api/invoices");
    }

    private async Task UpdateInvoiceStatusAsync(int invoiceId, string status)
    {
        _statusMessage = null;

        var request = new UpdateInvoiceStatusRequestDto(status);

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _statusMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        var response = await client.PatchAsJsonAsync(
            $"api/invoices/{invoiceId}/status",
            request);

        if (!response.IsSuccessStatusCode)
        {
            _statusMessage = await ApiErrorHelper.ReadErrorMessageAsync(
                response,
                "Fakturastatus kunne ikke opdateres.");

            return;
        }

        _statusMessage = status switch
        {
            "Sent" => "Fakturaen blev markeret som sendt.",
            "Paid" => "Fakturaen blev markeret som betalt.",
            _ => "Fakturastatus blev opdateret."
        };

        _invoices = await client.GetFromJsonAsync<List<InvoiceResponseDto>>(
            "api/invoices");
    }

    private async Task LoadAllInvoicesAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _filterMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _invoices =
            await client.GetFromJsonAsync<List<InvoiceResponseDto>>(
                "api/invoices");

        _filterMessage = null;
    }

    private async Task FilterInvoicesAsync()
    {
        _filterMessage = null;

        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _filterMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        if (_filterCustomerId <= 0 || _filterBillingPeriodId <= 0)
        {
            _invoices = new List<InvoiceResponseDto>();
            _filterMessage = "Vælg både kunde og periode.";
            return;
        }

        var response = await client.GetAsync(
            $"api/invoices/by-customer-and-period?customerId={_filterCustomerId}&billingPeriodId={_filterBillingPeriodId}");

        if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _invoices = new List<InvoiceResponseDto>();
            _filterMessage = "Ingen faktura fundet for den valgte kunde og periode.";
            return;
        }

        if (!response.IsSuccessStatusCode)
        {
            _filterMessage = "Fakturaer kunne ikke filtreres.";
            return;
        }

        var invoice =
            await response.Content.ReadFromJsonAsync<InvoiceResponseDto>();

        _invoices = invoice is null
            ? new List<InvoiceResponseDto>()
            : new List<InvoiceResponseDto> { invoice };

        _filterMessage = "Filter anvendt.";
    }

    private async Task LoadCustomersAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _customers =
            await client.GetFromJsonAsync<List<CustomerResponseDto>>(
                "api/customers");
    }

    private async Task LoadBillingPeriodsAsync()
    {
        var client = await CreateAuthorizedClientAsync();

        if (client is null)
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return;
        }

        _billingPeriods =
            await client.GetFromJsonAsync<List<BillingPeriodResponseDto>>(
                "api/billing-periods");
    }

    private async Task<HttpClient?> CreateAuthorizedClientAsync()
    {
        var authState =
            await AuthenticationStateProvider.GetAuthenticationStateAsync();

        var token = authState.User.FindFirst("access_token")?.Value;

        if (string.IsNullOrWhiteSpace(token))
        {
            _errorMessage = "Adgangstoken blev ikke fundet.";
            return null;
        }

        var client = HttpClientFactory.CreateClient("LadestanderApi");

        client.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        return client;
    }

    private string GetCustomerName(int customerId)
    {
        return _customers?
            .FirstOrDefault(customer => customer.CustomerId == customerId)?
            .FullName
            ?? $"Kunde #{customerId}";
    }

    private string GetBillingPeriodName(int billingPeriodId)
    {
        return _billingPeriods?
            .FirstOrDefault(period => period.BillingPeriodId == billingPeriodId)?
            .Name
            ?? $"Periode #{billingPeriodId}";
    }
}